# This stack must run from a shell that can reach the private OKE API.
# The recommended path is the Bastion tunnel helper in scripts/open-oke-api-tunnel.sh.

# Dedicated kubeconfig prepared by scripts/open-oke-api-tunnel.sh
kubeconfig_path = "~/.kube/oracle-oke-free.yaml"

# Argo CD
argocd_namespace = "argocd"
argocd_hostname  = "argocd.example.com"

# Enable Terraform-managed GitOps bootstrap.
argocd_bootstrap_enabled = false

# Private GitHub repository accessed by Argo CD over HTTPS with a PAT.
argocd_repo_url      = "https://github.com/jamestjw/cluster-gitops.git"
argocd_repo_username = "git"
argocd_repo_pat      = "replace-with-github-pat"

# Root Application created by Terraform. It points Argo CD at the directory
# that contains child Application manifests.
argocd_root_application_name     = "root-applications"
argocd_root_application_path     = "argocd"
argocd_root_application_revision = "main"

# ingress-nginx
ingress_namespace = "ingress-nginx"

# cert-manager / ACME DNS-01 via Cloudflare
cert_manager_namespace                  = "cert-manager"
cert_manager_cluster_resource_namespace = "cert-manager"
cert_manager_acme_email                 = "you@example.com"
cert_manager_dns_zone                   = "example.com"
cloudflare_api_token                    = "replace-with-cloudflare-dns-edit-token"
cloudflare_zone_name                    = "example.com"
cloudflare_argocd_dns_record_enabled    = true
cloudflare_wildcard_dns_record_enabled  = false
cloudflare_dns_record_proxied           = false

# Shared default wildcard certificate served by ingress-nginx.
ingress_default_wildcard_certificate_enabled = true

# Optional shared NFS-backed dynamic storage.
nfs_provisioner_enabled       = false
nfs_provisioner_namespace     = "storage"
nfs_storage_size              = "50Gi"
nfs_provisioner_chart_version = "4.0.18"

# OCI-specific NLB annotations are defined by default in variables.tf.
