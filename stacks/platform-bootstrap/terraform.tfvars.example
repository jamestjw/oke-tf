# This stack must run from a shell that can reach the private OKE API.
# The recommended path is the Bastion tunnel helper in scripts/open-oke-api-tunnel.sh.

# Dedicated kubeconfig prepared by scripts/open-oke-api-tunnel.sh
kubeconfig_path = "~/.kube/oracle-oke-free.yaml"

# Argo CD
argocd_namespace = "argocd"
argocd_hostname  = "argocd.example.com"

# ingress-nginx
ingress_namespace = "ingress-nginx"

# OCI-specific NLB annotations are defined by default in variables.tf.
